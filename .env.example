# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for classification + summarization
ANTHROPIC_MODEL=claude-sonnet-5

# Notion internal integration token (https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_...

# The Notion page ID that new paper pages should be created under.
# Get it from the page URL: notion.so/My-Page-<PAGE_ID>
# Remember to share that page with your integration in Notion's UI.
NOTION_PARENT_PAGE_ID=39131fa4ef4c815fb521c214eb79a6c3

# Optional: how many top-upvoted papers to consider before selecting 2
SHORTLIST_SIZE=15
